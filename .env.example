# ─────────────────────────────────────────────────────────────
# Ember & Oak — Environment Variables
# Copy this file to `.env.local` and fill in real values.
#   cp .env.example .env.local
# `.env.local` is git-ignored and will never be committed.
# ─────────────────────────────────────────────────────────────

# Token gating the /admin dashboard.
# Visit /admin?token=<ADMIN_TOKEN> to view reservations, newsletter,
# press inquiries and the captured mailbox.
# REQUIRED in production — if unset, the app falls back to the insecure
# default "demo". Generate a strong value, e.g. `openssl rand -hex 32`.
ADMIN_TOKEN=

# ─────────────────────────────────────────────────────────────
# Optional — used only by the Playwright verification scripts
# (scripts/verify.mjs, scripts/dialog-shot.mjs). Defaults to
# http://localhost:3000 when unset.
# ─────────────────────────────────────────────────────────────
# BASE=http://localhost:3000
